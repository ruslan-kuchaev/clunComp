@page
@model IndexModel
@{
    ViewData["Title"] = "Киберспорт Клуб";
}

<div class="hero-section">
    <div class="hero-bg"></div>
    <div class="hero-content">
        <div class="hero-badge">ПРОФЕССИОНАЛЬНЫЙ ГЕЙМИНГ</div>
        <h1 class="hero-title">КИБЕРСПОРТ<br/>КЛУБ</h1>
        <p class="hero-subtitle">Топовое железо • Комфортная атмосфера • Лучшие цены</p>
        <a href="/Booking/Create" class="btn-hero">ЗАБРОНИРОВАТЬ МЕСТО</a>
    </div>
    <div class="hero-stats">
        <div class="stat-item">
            <div class="stat-number">13</div>
            <div class="stat-label">Игровых мест</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Работаем</div>
        </div>
        <div class="stat-item">
            <div class="stat-number">400₽</div>
            <div class="stat-label">От/час</div>
        </div>
    </div>
</div>

<section class="zones-section">
    <div class="container">
        <div class="section-header">
            <h2>НАШИ ЗОНЫ</h2>
            <p>Выберите подходящий формат игры</p>
        </div>
        
        <div class="zones-grid">
            <div class="zone-card standard-zone">
                <div class="zone-header-text">
                    <div class="zone-subtitle">Игровой ПК и периферия</div>
                    <h3 class="zone-title">СТАНДАРТ</h3>
                </div>
                <div class="zone-image">
                    <img src="images/stan.png" alt="Стандарт зона" />
                </div>
                <div class="zone-footer">
                    <h4 class="zone-name">Общая Зона</h4>
                    <a href="/Booking/Create" class="btn-zone-link">Подробнее →</a>
                </div>
            </div>

            <div class="zone-card premium-zone">
                <div class="zone-header-text">
                    <div class="zone-subtitle">Монитор больше + ТОР мощнее</div>
                    <h3 class="zone-title">СТАНДАРТ+</h3>
                </div>
                <div class="zone-image">
                    <img src="images/stanp.png" alt="Стандарт+ зона" />
                </div>
                <div class="zone-footer">
                    <h4 class="zone-name">Лучшие Места</h4>
                    <a href="/Booking/Create" class="btn-zone-link">Подробнее →</a>
                </div>
            </div>

            <div class="zone-card console-zone">
                <div class="zone-header-text">
                    <div class="zone-subtitle">Приставка PS5 и 2 геймпада</div>
                    <h3 class="zone-title">ПРИСТАВКА</h3>
                </div>
                <div class="zone-image">
                    <img src="images/psp.png" alt="Приставка зона" />
                </div>
                <div class="zone-footer">
                    <h4 class="zone-name">Диван + PS5</h4>
                    <a href="/Booking/Create" class="btn-zone-link">Подробнее →</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="gallery-section">
    <div class="container">
        <div class="gallery-slider">
            <div class="slider-track">
                <div class="slide">
                    <img src="/images/placeholder.svg" alt="Фото клуба 1" />
                </div>
                <div class="slide">
                    <img src="/images/placeholder.svg" alt="Фото клуба 2" />
                </div>
                <div class="slide">
                    <img src="/images/placeholder.svg" alt="Фото клуба 3" />
                </div>
                <div class="slide">
                    <img src="/images/placeholder.svg" alt="Фото клуба 4" />
                </div>
                <div class="slide">
                    <img src="/images/placeholder.svg" alt="Фото клуба 5" />
                </div>
            </div>
            <div class="slider-dots">
                <span class="dot active" data-slide="0"></span>
                <span class="dot" data-slide="1"></span>
                <span class="dot" data-slide="2"></span>
                <span class="dot" data-slide="3"></span>
                <span class="dot" data-slide="4"></span>
            </div>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🖥️</div>
                <h3>Топовое железо</h3>
                <p>Последние модели видеокарт и процессоров для максимального FPS</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3>Высокая скорость</h3>
                <p>Интернет 1 Гбит/с и минимальный пинг для онлайн-игр</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎧</div>
                <h3>Комфорт</h3>
                <p>Игровые кресла, наушники премиум-класса и кондиционеры</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🕐</div>
                <h3>Круглосуточно</h3>
                <p>Работаем 24/7 без выходных и праздников</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>ГОТОВЫ К ИГРЕ?</h2>
            <p>Забронируйте место прямо сейчас и получите лучший игровой опыт</p>
            <a href="/Booking/Create" class="btn-cta">ЗАБРОНИРОВАТЬ</a>
        </div>
    </div>
</section>
