@page
@model CreateModel
@{
    ViewData["Title"] = "Забронировать место";
}

<div class="booking-page">
    <div class="page-header">
        <h1>ВЫБЕРИТЕ МЕСТО</h1>
        <p class="subtitle">Забронируйте компьютер или консоль прямо сейчас</p>
    </div>

    @{
        var zones = Model.Computers.GroupBy(c => c.Zone).OrderBy(g => g.Key == "VIP" ? 0 : g.Key == "Стандарт" ? 1 : 2);
    }

    @foreach (var zone in zones)
    {
        <div class="zone-section">
            <div class="zone-header">
                <h2>@zone.Key</h2>
                <span class="zone-price">от @zone.Min(c => c.PricePerHour)₽/час</span>
            </div>
            
            <div class="computers-grid">
                @foreach (var computer in zone)
                {
                    <div class="computer-card @(!computer.IsAvailable ? "unavailable" : "") @(computer.Zone == "VIP" ? "vip" : "")">
                        <div class="computer-image">
                            <img src="@computer.ImageUrl" alt="@computer.Name" />
                            @if (!computer.IsAvailable)
                            {
                                <div class="unavailable-overlay">ЗАНЯТО</div>
                            }
                            else
                            {
                                <div class="available-badge">ДОСТУПНО</div>
                            }
                        </div>
                        <div class="computer-info">
                            <div class="computer-header">
                                <h3>@computer.Name</h3>
                                @if (computer.Zone == "VIP")
                                {
                                    <span class="vip-badge">★ VIP</span>
                                }
                            </div>
                            <p class="specs">@computer.Specifications</p>
                            <div class="computer-footer">
                                <p class="price">@computer.PricePerHour₽<span>/час</span></p>
                                @if (computer.IsAvailable)
                                {
                                    <button class="btn-book" onclick="selectComputer(@computer.Id, '@computer.Name', @computer.PricePerHour, '@computer.Zone')">
                                        ЗАБРОНИРОВАТЬ
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div id="bookingModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal()">&times;</span>
            <h2>ОФОРМЛЕНИЕ БРОНИ</h2>
            <p class="selected-computer">Место: <strong id="computerName"></strong></p>
            
            <form method="post">
                <input type="hidden" asp-for="Booking.ComputerId" id="computerId" />
                
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Booking.UserPhone">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                            Телефон
                        </label>
                        <input asp-for="Booking.UserPhone" class="form-control" type="tel" placeholder="+7 (999) 123-45-67" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Booking.BookingDate">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            Дата
                        </label>
                        <input asp-for="Booking.BookingDate" class="form-control" type="date" required />
                    </div>

                    <div class="form-group">
                        <label asp-for="Booking.StartTime">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                            Время
                        </label>
                        <input asp-for="Booking.StartTime" class="form-control" type="time" required />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Booking.DurationHours">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        Продолжительность
                    </label>
                    <div class="duration-buttons">
                        <button type="button" class="duration-btn" onclick="selectDuration(1)">1 час</button>
                        <button type="button" class="duration-btn" onclick="selectDuration(2)">2 часа</button>
                        <button type="button" class="duration-btn" onclick="selectDuration(3)">3 часа</button>
                        <button type="button" class="duration-btn" onclick="selectDuration(4)">4 часа</button>
                        <button type="button" class="duration-btn" onclick="selectDuration(5)">5 часов</button>
                        <button type="button" class="duration-btn" onclick="selectDuration(6)">6 часов</button>
                    </div>
                    <input asp-for="Booking.DurationHours" type="hidden" value="1" />
                </div>

                <div class="total-section">
                    <div class="total-row">
                        <span>Стоимость:</span>
                        <span id="totalPrice">0</span>₽
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">ПОДТВЕРДИТЬ БРОНЬ</button>
                    <button type="button" class="btn-secondary" onclick="closeModal()">ОТМЕНА</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let selectedPrice = 0;
        let selectedDuration = 1;

        function selectComputer(id, name, price, zone) {
            document.getElementById('computerId').value = id;
            document.getElementById('computerName').textContent = name + ' (' + zone + ')';
            selectedPrice = price;
            document.getElementById('bookingModal').style.display = 'flex';
            calculateTotal();
        }

        function closeModal() {
            document.getElementById('bookingModal').style.display = 'none';
        }

        function selectDuration(hours) {
            selectedDuration = hours;
            document.querySelector('[name="Booking.DurationHours"]').value = hours;
            
            document.querySelectorAll('.duration-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            calculateTotal();
        }

        function calculateTotal() {
            const total = selectedPrice * selectedDuration;
            document.getElementById('totalPrice').textContent = total;
        }

        window.onclick = function(event) {
            const modal = document.getElementById('bookingModal');
            if (event.target == modal) {
                closeModal();
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date().toISOString().split('T')[0];
            document.querySelector('[name="Booking.BookingDate"]').setAttribute('min', today);
        });
    </script>
}
