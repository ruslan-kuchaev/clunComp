@page
@model clunComp.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Забыли пароль?";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <h1>ВОССТАНОВЛЕНИЕ</h1>
            <p>Введите ваш email для восстановления пароля</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="example@mail.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn-primary btn-full">ОТПРАВИТЬ</button>
            
            <div class="auth-links">
                <a asp-page="./Login">Вернуться ко входу</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
